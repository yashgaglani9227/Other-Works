body{
    background:#f5f5f5;
    font-family:Arial, sans-serif;
}

.menu{
    width:700px;
    margin:30px auto;
    background:#fff8ec;
    border:3px solid #333;
    padding:20px;
}

h1{
    text-align:center;
    color:#d35400;
}

h2{
    color:#1f4e79;
    margin-top:20px;
}

ul{
    list-style:none;
    padding-left:10px;
}

li{
    margin:10px 0;
    color:#444;
    font-size:18px;
}

li i{
    color:orange;
    margin-right:8px;
}

.footer{
    text-align:center;
    color:gray;
    margin-top:30px;
    font-style:italic;
}